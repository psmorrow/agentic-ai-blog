# Required: Google Safe Browsing API for article URL malware/phishing checks
# Get a key: https://developers.google.com/safe-browsing/v4/get-started
#GOOGLE_SAFE_BROWSING_API_KEY=

# Required: OpenAI API key for LLM, DALL-E, and Moderation
#OPENAI_API_KEY=

# Required: Serper API key for web search (article discovery)
# Get a key: https://serper.dev/api-key
#SERPER_API_KEY=

# Optional: Google Analytics 4 measurement ID (feed page: page_view, post_view, article_click)
#GA_MEASUREMENT_ID=G-XXXXXXX

# Optional: Server port (default 3000)
#PORT=3000
